# ============================================================
# Community Health Intelligence Assistant — Environment Config
# ============================================================
# Copy this to .env and fill in your values.

# ---------- Google Gemini API ----------
GEMINI_API_KEY=your-gemini-api-key

# ---------- GCP Configuration (only if LLM_PROVIDER=vertex_ai) ----------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ---------- LLM Provider ----------
# Options: "gemini" (API key), "vertex_ai" (GCP), or "groq" (fallback)
LLM_PROVIDER=gemini

# ---------- Groq (only if LLM_PROVIDER=groq) ----------
GROQ_API_KEY=your-groq-api-key

# ---------- Embedding Backend ----------
# Options: "vertex_ai" or "local" (SentenceTransformers)
EMBEDDING_BACKEND=local

# ---------- Vector Store Backend ----------
# Options: "chromadb" (local) or "alloydb" (GCP)
VECTOR_STORE_BACKEND=chromadb

# ---------- AlloyDB (only if VECTOR_STORE_BACKEND=alloydb) ----------
ALLOYDB_HOST=
ALLOYDB_PORT=5432
ALLOYDB_DB=health_intelligence
ALLOYDB_USER=
ALLOYDB_PASSWORD=
